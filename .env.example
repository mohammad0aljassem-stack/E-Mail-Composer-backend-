# =============================================================================
# Transport worker configuration (example values ONLY — never commit real ones).
# The worker validates this at startup and FAILS CLOSED on anything invalid.
# =============================================================================

# Master feature flag. DEFAULT false. When false the worker does NOT connect to
# IMAP/SMTP, does NOT start the send worker, and does NOT decrypt any credential.
MAIL_TRANSPORT_V1_ENABLED=false

# Least-privileged worker DB connection (the transport_worker role).
# NEVER point this at production (see scripts/test-db.sh for local testing).
DATABASE_URL=postgresql://transport_worker:CHANGE_ME@localhost:54330/transport_test

# pg-boss schema (isolates the queue tables).
PGBOSS_SCHEMA=pgboss

# AES-256 credential keyring. Format: "version:base64Key,version:base64Key".
# Each key MUST decode to exactly 32 bytes. Generate a synthetic test key with:
#   node -e "console.log('1:'+require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED only when MAIL_TRANSPORT_V1_ENABLED=true. Never commit a real key.
CREDENTIAL_KEYRING=
CREDENTIAL_ACTIVE_KEY_VERSION=1

# Opaque, stable worker instance id (defaults to worker-<pid>).
WORKER_ID=

# Global kill switch: when true the worker performs NO delivery at all.
TRANSPORT_GLOBAL_KILL_SWITCH=false

# Observability + timeouts.
LOG_LEVEL=info
HEARTBEAT_INTERVAL_MS=15000
CLAIM_LEASE_MS=60000
SMTP_TIMEOUT_MS=30000
IMAP_COMMAND_TIMEOUT_MS=30000

# --- Test-only provisioning CLI (src/entrypoints/provision-credential.ts) -----
# The CLI reads the synthetic secret JSON from STDIN, never argv. It REFUSES to
# run against production project refs / *.supabase.co URLs.
PROVISION_WORKSPACE_ID=
PROVISION_MAILBOX_ID=
